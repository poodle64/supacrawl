# uv-managed dev environment (Python 3.14). uv builds .venv from uv.lock and
# direnv puts it on PATH, refreshing on manifest changes.

# Cascade shared config/secrets from the master project's .envrc.local.
source_up

[[ -f .envrc.local ]] && source .envrc.local

if ! has uv; then
  echo "direnv: 'uv' not found on PATH; install it (nix-darwin) before working here" >&2
  return 0
fi

watch_file pyproject.toml uv.lock
uv sync --quiet --all-groups

export VIRTUAL_ENV="$PWD/.venv"
PATH_add "$PWD/.venv/bin"
