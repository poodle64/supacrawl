# Environment
.env
.venv
venv

# Python artefacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# Build outputs
dist/
build/
*.egg-info/

# Coverage
.coverage
htmlcov/

# Test output files
test_*_results.json

# Debug scripts (keep in root for convenience, don't commit)
debug_*.py
test_*.py
!tests/

# Working docs (ephemeral, don't commit)
AUDIT_*.md
BUG_REPORT_*.md
DOCUMENTATION_*.md
ROADMAP_*.md
SPA_*.md

# Debug artifacts
audit_artifacts/

# Project data
corpora/*
!corpora/.gitkeep

# Local site configs
sites/*.local.yaml
sites/debug*.yaml
sites/audit*.yaml

# Claude Code configuration
.claude/CLAUDE.local.md
.claude/settings.local.json
.claude/.sessions/

